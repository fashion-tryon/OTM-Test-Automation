import { By } from "selenium-webdriver";
import ojwd, { DriverLike, register } from "@oracle/oraclejet-webdriver";
import { @CLASSNAME@ } from "./@CLASSNAME@";
export { @CLASSNAME@ };

/**
 * Create an instance of [[@CLASSNAME@]].  This function will first wait for
 * the element to appear in the DOM before trying to locate it.
 * @example
 * <code>
 * const el = await @CAMELNAME@(driver, By.id('my-@NAME@'))
 * </code>
 * @param driver A WebDriver/WebElement instance used to locate the component
 * element.
 * @param by The By locator with which to find the element
 */
export async function @CAMELNAME@(driver: DriverLike, by: By): Promise<@CLASSNAME@> {
  const webEl = await driver.findElement(by);
  // Check that the element is of type @CLASSNAME@
  if (!(webEl instanceof @CLASSNAME@)) {
    const tagName = await webEl.getTagName();
    throw Error(`Locator '${by}' located a <${tagName}>, but expected <@NAME@>`);
  }
  return webEl;
}

register("@NAME@", @CLASSNAME@);
