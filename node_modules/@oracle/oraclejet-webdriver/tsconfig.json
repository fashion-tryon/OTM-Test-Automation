{
  "compilerOptions": {
    "rootDir": ".",
    "alwaysStrict": true,
    "module": "commonjs",
    "target": "es2017",
    "noImplicitAny": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "noStrictGenericChecks": true,
    "moduleResolution": "node"
  },
  "include": [
    "index.ts",
    "elements/**/*.ts"
  ]
}
