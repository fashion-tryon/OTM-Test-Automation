{
  "name": "otm-automation-portal",
  "version": "1.0.0",
  "description": "OTM Test Automation Portal — React frontend, Node backend, SQLite, Playwright",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "build": "SKIP_BUILD=1 npm install --prefix client && npm run build --prefix client",
    "postinstall": "node -e \"if(!process.env.SKIP_BUILD)require('child_process').execSync('npm run build',{stdio:'inherit'})\"",
    "test:login": "npx playwright test tests/login.spec.ts",
    "test:all": "npx playwright test",
    "report": "npx allure generate allure-results --clean -o allure-report"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "dotenv": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "allure-commandline": "latest",
    "allure-playwright": "latest",
    "typescript": "latest"
  }
}
